{
  "name": "@pcampus/thai-romanization",
  "version": "1.0.0",
  "description": "Rule-based Thai to Latin romanization with morpheme segmentation, loanwords, and province support",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "thai-romanize": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./packs/core": {
      "types": "./dist/packs/core.d.ts",
      "import": "./dist/packs/core.js",
      "require": "./dist/packs/core.cjs"
    },
    "./packs/geo": {
      "types": "./dist/packs/geo.d.ts",
      "import": "./dist/packs/geo.js",
      "require": "./dist/packs/geo.cjs"
    },
    "./packs/calendar": {
      "types": "./dist/packs/calendar.d.ts",
      "import": "./dist/packs/calendar.js",
      "require": "./dist/packs/calendar.cjs"
    },
    "./packs": {
      "types": "./dist/packs/index.d.ts",
      "import": "./dist/packs/index.js",
      "require": "./dist/packs/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "USAGE.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts src/packs/core.ts src/packs/geo.ts src/packs/calendar.ts src/packs/index.ts --format cjs,esm --dts --clean --tsconfig tsconfig.build.json",
    "dev": "tsup src/index.ts src/cli.ts src/packs/core.ts src/packs/geo.ts src/packs/calendar.ts src/packs/index.ts --format cjs,esm --watch --dts",
    "lint": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run",
    "playground": "next dev playground",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "thai",
    "romanization",
    "transliteration",
    "rtgs",
    "thai-language",
    "nlp"
  ],
  "author": "Pcampus Studio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pcampus-Studio/Pcampus-thai-romanization.git"
  },
  "homepage": "https://github.com/Pcampus-Studio/Pcampus-thai-romanization#readme",
  "bugs": {
    "url": "https://github.com/Pcampus-Studio/Pcampus-thai-romanization/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "autoprefixer": "^10.5.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
